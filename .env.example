# MuchuCraft shared configuration — copy to .env and adjust
PORT=8080
MC_HOST=127.0.0.1
MC_PORT=25565
# Pinned Minecraft version (must be supported by the bundled web client AND Paper)
MC_VERSION=1.21.11
RCON_PORT=25575
RCON_PASSWORD=change-me-to-a-long-random-string
SESSION_TTL_HOURS=24
# Domain/URI embedded in the signed Solana sign-in message; must match the page host
SIWS_DOMAIN=localhost:8080
SIWS_URI=http://localhost:8080/login/
DB_PATH=gateway/data/muchucraft.db
# World seed, filled by server setup with a scenic seed
MC_SEED=

# --- MUCHU token bridge (1:1 in-game <-> on-chain) ---
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
MUCHU_MINT=R76wEBCrjipkHB8999utYpsECG6qM5S7a49YWKmuchu
MUCHU_DECIMALS=6
TREASURY_KEYPAIR_PATH=/home/ubuntu/.muchucraft/treasury-mainnet.json
BRIDGE_PORT=8091
BRIDGE_TOKEN=generate-a-long-random-string
WITHDRAWALS_ENABLED=true
WITHDRAW_MIN=1

# --- Deposits & earn gate ---
DEPOSIT_MIN=1
DEPOSIT_GATE_MIN=0
DEPOSIT_POLL_SECONDS=20

# Client-facing MC version (browser client renders this; ViaBackwards bridges to the server version)
CLIENT_MC_VERSION=1.21.4

# Address players SEE as the server (proxy always dials MC_HOST:MC_PORT internally)
PUBLIC_SERVER_ADDRESS=web.muchu.app:25565
MUCHU_TOKEN_PROGRAM=token-2022
WITHDRAW_MAX_PCT_OF_TREASURY=10
