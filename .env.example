# MuchuCraft shared configuration — copy to .env and adjust
PORT=8080
MC_HOST=127.0.0.1
MC_PORT=25565
# Pinned Minecraft version (must be supported by the bundled web client AND Paper)
MC_VERSION=1.21.11
RCON_PORT=25575
RCON_PASSWORD=change-me-to-a-long-random-string
SESSION_TTL_HOURS=24
# Domain/URI embedded in the signed Solana sign-in message; must match the page host
SIWS_DOMAIN=localhost:8080
SIWS_URI=http://localhost:8080/login/
DB_PATH=gateway/data/muchucraft.db
# World seed, filled by server setup with a scenic seed
MC_SEED=
